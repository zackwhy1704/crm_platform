# ============================================================
# CRM Platform — Environment variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# --- Meta WhatsApp Cloud API ---
# Get from https://developers.facebook.com/apps (WhatsApp → API Setup)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_BUSINESS_ACCOUNT_ID=

# --- Meta Lead Ads (same app) ---
META_APP_SECRET=
META_LEAD_ADS_VERIFY_TOKEN=choose-a-random-string

# --- Anthropic Claude ---
# Using Haiku 4.5 for lead qualification — cheap and fast
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Celery / Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- App config ---
ENV=development
LOG_LEVEL=INFO
INTERNAL_API_SECRET=generate-a-random-string

# --- Frontend (Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
